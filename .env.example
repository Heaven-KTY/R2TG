R2TG_HOST=0.0.0.0
R2TG_PORT=4433
R2TG_PATH=/r2tg

# Production should provide trusted TLS files.
R2TG_TLS_CERT=/absolute/path/to/server.crt
R2TG_TLS_KEY=/absolute/path/to/server.key

# Set this to enable token auth.
R2TG_AUTH_SECRET=replace-with-a-long-random-secret

# Production default is off. Set to 1 only when serving the browser module from R2TG.
R2TG_SERVE_CLIENT=0

# Demo routes are off by default.
R2TG_ENABLE_DEMO_ROUTES=0

# open | basic | controlled | strict
R2TG_SECURITY_PROFILE=basic

# Comma-separated origins. Required for strict profile.
R2TG_ORIGIN_ALLOWLIST=https://example.com,https://admin.example.com

R2TG_MAX_DATAGRAM_BYTES=4096
R2TG_MAX_STREAM_FRAME_BYTES=65536
R2TG_MAX_PENDING_STREAM_BUFFER_BYTES=262144

# Periodic cleanup for incomplete FEC recovery groups.
R2TG_FEC_FLUSH_INTERVAL_MS=1000

R2TG_RATE_LIMIT=1
R2TG_RATE_LIMIT_DATAGRAM_PER_SECOND=100
R2TG_RATE_LIMIT_STREAM_FRAME_PER_SECOND=30
R2TG_RATE_LIMIT_COMMAND_PER_SECOND=10
R2TG_RATE_LIMIT_ON_EXCEEDED=drop

R2TG_ENFORCE_SCOPE=0
R2TG_REPLAY_PROTECTION=0
R2TG_REPLAY_TTL_MS=300000

# Strict profile only. Do not reuse R2TG_AUTH_SECRET for this value.
R2TG_FRAME_HMAC=0
R2TG_FRAME_HMAC_SECRET=replace-with-a-separate-hmac-secret
